# Backend
NODE_ENV=production
PORT=3000
APP_BASE_URL=https://api.example.com
AUTH_TOKEN_SECRET=replace-with-a-long-random-secret
AUTH_TOKEN_EXPIRES_SECONDS=7200

# WeChat Mini Program login
WECHAT_AUTH_PROVIDER=wechat
WECHAT_MINI_APP_ID=wx_your_mini_program_appid
WECHAT_MINI_APP_SECRET=your_mini_program_appsecret

# WeChat Pay v3 / Mini Program JSAPI payment
PAYMENT_PROVIDER=wechat_pay
WECHAT_PAY_MCH_ID=your_mch_id
WECHAT_PAY_MCH_SERIAL_NO=your_merchant_api_certificate_serial_no
WECHAT_PAY_PRIVATE_KEY_PATH=/secure/wechatpay/apiclient_key.pem
WECHAT_PAY_API_V3_KEY=your_32_byte_api_v3_key
WECHAT_PAY_NOTIFY_URL=https://api.example.com/api/payments/wechat/notify
WECHAT_PAY_PLATFORM_PUBLIC_KEY_PATH=/secure/wechatpay/wechatpay_public_key.pem

# Door access. Keep mock until the real lock vendor is selected.
ACCESS_CODE_PEPPER=replace-with-a-long-random-secret

# Frontend / merchant-web build
VITE_API_BASE_URL=https://api.example.com
VITE_ENABLE_DEV_AUTO_LOGIN=false
